[user]
  name = Brian Riley
  email = 97886+brianriley@users.noreply.github.com
  signingkey = 97886+brianriley@users.noreply.github.com
[alias]
  activity = "!f() { git log --name-only --oneline \"${1:---since=1970}\" | tail -n +2 | sort | uniq -c | sort; }; f"
  branches = branch --sort=-committerdate
  bugs = "!f() { git log -i -E --grep=\"fix|bug|broken\" --name-only --format='' | sort | uniq -c | sort -nr | head -20; }; f"
  cpm = "!f() { git log --format='%ad' --date=format:'%Y-%m' | sort | uniq -c; }; f" # commits per month
  firefights = "!f() { git log --oneline --since=\"1 year ago\" | grep -iE 'revert|hotfix|emergency|rollback'; }; f"
  graph = log --graph --pretty=format:'%C(yellow)%h%Creset %C(cyan)%D%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
  join = merge --no-ff
  leaderboard = shortlog -sn
  recap = "!f() { git log -p --since='$1' --reverse; }; f"
  rollback = reset HEAD^
  search = "!f() { git log --all --grep=$1; }; f"
  st = status
  today = log --since=\"00:00:00\" --all --no-merges --oneline --author='Brian Riley'
  unstage = reset HEAD --
[color]
  ui = true
[push]
  default = tracking
[rerere]
  enabled = true
[core]
  editor = nvim
  excludesfile = ~/.gitignore
[merge]
  tool = vimdiff
[commit]
  gpgsign = true
[help]
  autocorrect = 1
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[fetch]
  prune = true
[init]
	defaultBranch = main
